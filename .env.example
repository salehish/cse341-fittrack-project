# Copy this file to .env and fill in real values. NEVER commit .env.

# MongoDB Atlas connection string.
# Format: mongodb+srv://<user>:<password>@<cluster>.xxxxx.mongodb.net/fittrack?retryWrites=true&w=majority
MONGO_URI=

# Port the server listens on (Render sets this automatically in production).
PORT=3000

# GitHub OAuth (from your GitHub OAuth App: Settings > Developer settings > OAuth Apps)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Leave blank locally (defaults to /auth/github/callback); set the full URL on Render.
GITHUB_CALLBACK_URL=

# Any long random string used to sign the session cookie.
SESSION_SECRET=
